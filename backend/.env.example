# ═══════════════════════════════════════════════════════
# DIALBEE API — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://dialbee:dialbee_pass_2024@localhost:5432/dialbee
DATABASE_POOL_MAX=10
DATABASE_LOGGING=true

# Redis
REDIS_URL=redis://:dialbee_redis_2024@localhost:6379
REDIS_TTL=300

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ES_PASSWORD=

# JWT
JWT_ACCESS_SECRET=dialbee_access_secret_min_32_chars_here_2024
JWT_REFRESH_SECRET=dialbee_refresh_secret_min_32_chars_here_2024
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# AWS (local dev: use MinIO or dummy values)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=dummy_for_local
AWS_SECRET_ACCESS_KEY=dummy_for_local
AWS_S3_BUCKET=dialbee-media-dev
AWS_CLOUDFRONT_URL=http://localhost:9000/dialbee-media-dev

# Email (Mailhog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dialbee.com

# Stripe (use test keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STANDARD_MONTHLY=price_standard_monthly_id
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id

# Paystack (Africa — use test keys)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Twilio (SMS — optional for dev)
TWILIO_ACCOUNT_SID=AC_your_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# WhatsApp Business API (optional for dev)
WHATSAPP_API_KEY=your_whatsapp_key
WHATSAPP_PHONE_ID=your_phone_id

# Admin
ADMIN_EMAIL=admin@dialbee.com
ADMIN_PASSWORD=Admin@Dialbee2024!

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
